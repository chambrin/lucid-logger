{
  "name": "lucid-logger",
  "version": "0.1.1",
  "description": "A structured and typed logger for Node/Next/Fastify, with clean JSON output in production and readable rendering in development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "bench": "npx tsx benchmarks/performance.ts",
    "example:basic": "npx tsx examples/basic.ts",
    "example:multi": "npx tsx examples/multiple-destinations.ts",
    "example:rotation": "npx tsx examples/file-rotation.ts",
    "example:dev": "npx tsx examples/development-mode.ts",
    "example:prod-vs-dev": "npx tsx examples/production-vs-dev.ts"
  },
  "keywords": [
    "logger",
    "logging",
    "structured",
    "json",
    "structured-logging",
    "pino",
    "winston",
    "signale",
    "typescript",
    "nodejs",
    "nextjs",
    "fastify",
    "error-handling",
    "log-levels",
    "file-rotation"
  ],
  "author": "Chambrin <contact@chambrin.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chambrin/lucid-logger"
  },
  "homepage": "https://github.com/chambrin/lucid-logger#readme",
  "bugs": {
    "url": "https://github.com/chambrin/lucid-logger/issues"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
